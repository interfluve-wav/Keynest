{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyChest",
  "version": "0.2.0",
  "identifier": "com.keychest.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && (cd agent-chest-proxy && go build -o ../src-tauri/ ./cmd/agent-chest-proxy/)",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KeyChest",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "agent-chest-proxy"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
